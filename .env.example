# Konfigurasi Database ArenHost
# Ubah localhost menjadi IP/Domain database server jika aplikasi berjalan di server yang berbeda.
DATABASE_HOST="localhost"
DATABASE_USER="GANTI_DENGAN_USER_DATABASE"
DATABASE_PASSWORD="GANTI_DENGAN_PASSWORD_DATABASE"
DATABASE_NAME="GANTI_DENGAN_NAMA_DATABASE"
DATABASE_PORT="3306"

# Prisma Database URL
# Pastikan password yang mengandung karakter khusus seperti @ di-encode menjadi %40
DATABASE_URL="mysql://USER:PASSWORD_ENCODED@localhost:3306/NAMA_DATABASE"

# NextAuth Configuration
# Generate secret dengan: openssl rand -base64 48
NEXTAUTH_SECRET="GANTI_DENGAN_SECRET_RANDOM_PANJANG"
NEXTAUTH_URL="https://GANTI_DENGAN_DOMAIN_ANDA"
