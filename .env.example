# Prisma Database URL (MySQL)
# Password dengan karakter khusus seperti @ harus di-encode (contoh: @ -> %40)
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/NAMA_DATABASE"

# Prisma Client Engine Type
PRISMA_CLIENT_ENGINE_TYPE="library"

# NextAuth Configuration
# Generate secret dengan: openssl rand -base64 48
NEXTAUTH_SECRET="GANTI_DENGAN_SECRET_RANDOM_PANJANG"
NEXTAUTH_URL="https://GANTI_DENGAN_DOMAIN_ANDA"

# Environment
NODE_ENV="production"

# Web Push (opsional, untuk notifikasi push)
# Generate dengan: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
