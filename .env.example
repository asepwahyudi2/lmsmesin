# =========================
# DATABASE - TiDB Cloud Serverless (GRATIS 5GB, MySQL compatible)
# =========================
# 1. Daftar https://tidbcloud.com -> Create Cluster Serverless -> Region Singapore
# 2. Database -> Create DB lms_mesin_db
# 3. Connect -> Connection String -> copy.
# Format: mysql://<USER>:<PASSWORD>@<HOST>:4000/<DB>?sslaccept=strict
# Password dengan @ harus encode %40
# Contoh TiDB: mysql://xxxx.root@aws-ap-northeast-1.prod.aws.tidbcloud.com:4000/lms_mesin_db?sslaccept=strict&connection_limit=5
#
# Alternatif gratis MySQL lain:
# - Aiven MySQL Free (mysql://...)
# - PlanetScale (butuh driver tambahan)
#
# Untuk Postgres gratis (ubah schema provider -> postgresql):
# - Neon https://neon.tech
# - Supabase https://supabase.com
#
# Lokal Docker tetap bisa pakai: mysql://lms_user:lms_secure_password_123@localhost:3306/lms_mesin_db
DATABASE_URL="mysql://USER:PASSWORD@GATEWAY-HOST:4000/lms_mesin_db?sslaccept=strict&connection_limit=5&pool_timeout=10"

# Prisma engine wajib library untuk Vercel serverless
PRISMA_CLIENT_ENGINE_TYPE="library"

# =========================
# NextAuth
# =========================
# Generate: openssl rand -base64 48  ATAU  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="GANTI_DENGAN_RANDOM_48_CHAR"
# Lokal: http://localhost:3000 | Vercel: https://namaproject.vercel.app (WAJIB HTTPS)
NEXTAUTH_URL="https://GANTI-DENGAN-DOMAIN-VERCEL.vercel.app"

# =========================
# BasePath - KOSONGKAN untuk Vercel (root domain)
# Isi /lmsmesin hanya untuk cPanel subfolder lama
# =========================
NEXT_PUBLIC_BASE_PATH=""

# =========================
# Vercel Blob Storage - WAJIB untuk upload persisten di Vercel
# =========================
# Vercel Dashboard -> Storage -> Create Blob -> Copy token
# Jika kosong di Vercel: upload akan ERROR (memaksa pakai Blob agar tidak hilang di /tmp)
# Lokal tidak perlu (akan simpan di public/uploads)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# =========================
# Optional - VAPID Web Push
# Generate: npx web-push generate-vapid-keys
# =========================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# =========================
# Optional - WhatsApp Fonnte
# =========================
WHATSAPP_TOKEN=""
WHATSAPP_TARGET_GROUP_OR_PHONE=""

# Node env - Vercel auto set production
NODE_ENV="production"
